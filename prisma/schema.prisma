generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id           String   @id @default(cuid())
  name         String   @default("Untitled Session")
  pattern      String
  testString   String   @default("")
  engine       String   @default("javascript")
  steps        String   @default("[]")
  captures     String   @default("[]")
  redosWarning Boolean  @default(false)
  complexity   String   @default("O(n)")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shareableLinks ShareableLink[]

  @@index([createdAt])
}

model ShareableLink {
  id        String    @id @default(cuid())
  sessionId String
  token     String    @unique
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  session   Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([token])
}
